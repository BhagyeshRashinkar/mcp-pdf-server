# LLM API Configuration
API_KEY=your_nvidia_api_key_here

# Models
# DO NOT change EMBED_MODEL if you have already ingested data without re-ingesting.
EMBED_MODEL=nvidia/nv-embedqa-e5-v5
GEN_MODEL=qwen/qwen2.5-coder-32b-instruct

# Qdrant Collection Name (customize for your use case)
COLLECTION_NAME=documents

# Ingestion Rate Limiting
# These are only used during 'npm run ingest'
EMBED_BATCH_SIZE=15
EMBED_MAX_RETRIES=3
EMBED_COOLOFF_MS=500

# Network
# Use http://localhost:6333 for local ingestion
QDRANT_URL=http://localhost:6333
